    text += "━━━━━━━━━━━━━━━━━━━\n"
    text += f"📅 Действуют с {tariffs[0][0].effective_from.strftime('%d.%m.%Y')}"

    photo = FSInputFile(IMG_DIR / "tariffs.png")
    await message.answer_photo(photo, caption=text, reply_markup=main_menu)
