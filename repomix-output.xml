    elements.append(Spacer(1, 10*mm))

    # Footer
    elements.append(Paragraph(
        "Оплатите до 15 числа следующего месяца.",
        styles["Normal"],
    ))

    doc.build(elements)
    buffer.seek(0)
    return buffer
