    color: #16a34a;
    border: 1px solid rgba(22,163,74,.3);
    border-radius: .5rem;
    font-weight: 600;
}
.btn-outline-success:hover { background: rgba(22,163,74,.05); color: #16a34a; }

.btn-outline-danger {
    color: var(--error);
    border: 1px solid rgba(186,26,26,.3);
    border-radius: .5rem;
    font-weight: 600;
}
.btn-outline-danger:hover { background: rgba(186,26,26,.05); color: var(--error); }

.btn-sm {
    border-radius: .5rem;
    padding: .25rem .625rem;
    transition: all 200ms;
}
.btn-sm:hover { transform: scale(1.05); }

/* === FORMS (exact Stitch values) === */
.form-control, .form-select {
    background: var(--surface-highest);
    border: none;
    border-radius: .5rem;
    color: var(--on-surface);
    padding: .625rem 1rem;
    font-size: .875rem;
    transition: all 200ms;
}
.form-control:focus, .form-select:focus {
    background: var(--surface-card);
    border: none;
    box-shadow: 0 0 0 2px rgba(0,88,190,.2);
    color: var(--on-surface);
}
.form-control::placeholder { color: var(--outline); }
.form-label {
    color: var(--outline);
    font-weight: 700;
    font-size: .6875rem;
    text-transform: uppercase;
    letter-spacing: .05em;
    margin-bottom: .25rem;
}
.form-select option { background: var(--surface-card); color: var(--on-surface); }

/* === ALERTS === */
.alert { border-radius: .75rem; border: none; font-size: .875rem; }
.alert-danger  { background: var(--error-container); color: var(--on-error-container); }
.alert-success { background: #dcfce7; color: #166534; }
.alert-info    { background: #dbeafe; color: #1e40af; }
.alert-warning { background: var(--tertiary-fixed); color: var(--on-tertiary-fixed-variant); }

/* === CODE === */
code {
    background: var(--primary-fixed);
    color: var(--on-primary-fixed-variant);
    padding: .15em .5em;
    border-radius: 4px;
    font-size: .85em;
}

/* === LIST GROUP === */
.list-group-item {
    background: transparent;
    border-color: var(--surface-container);
    color: var(--on-surface);
}

/* === PAGINATION (exact Stitch) === */
.pagination .page-link {
    background: transparent;
    border: none;
    color: var(--secondary);
    border-radius: .5rem;
    margin: 0 2px;
    font-weight: 500;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 200ms;
}
.pagination .page-link:hover { background: var(--surface-high); }
.pagination .page-item.active .page-link {
    background: var(--primary);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 4px 6px -1px rgba(0,88,190,.1);
}
.pagination .page-item.disabled .page-link {
    background: transparent;
    color: var(--outline-variant);
}

/* === HR === */
hr { border-color: rgba(194,198,214,.2); }

/* === BORDER === */
.border { border-color: rgba(194,198,214,.2) !important; }
.border.rounded { border-radius: .5rem !important; }

/* === SCROLLBAR === */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--outline-variant); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--outline); }
.sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); }

/* === btn-close fix === */
.btn-close { filter: none; }

/* === RESPONSIVE === */
@media (max-width: 768px) {
    .sidebar {
        width: 60px !important;
        padding: 10px !important;
    }
    .sidebar .nav-link span,
    .sidebar h5,
    .sidebar .mt-auto { display: none; }
}
</file>

<file path="app/templates/base.html">
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Панель управления{% endblock %} — ЖКУ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="/static/css/style.css?v={{ range(100000)|random }}" rel="stylesheet">
