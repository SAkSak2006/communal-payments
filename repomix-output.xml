                </a>
                <form method="post" action="/admin/import/residents" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input type="file" class="form-control" name="file" accept=".xlsx,.xls" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-upload"></i> Загрузить жителей
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Import readings -->
    <div class="col-md-6">
        <div class="card card-dashboard">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-clipboard-data"></i> Импорт показаний</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Загрузите Excel-файл с показаниями счётчиков. Показания будут автоматически привязаны к счётчикам.
                </p>
                <a href="/admin/import/template/readings" class="btn btn-outline-secondary btn-sm mb-3">
                    <i class="bi bi-download"></i> Скачать шаблон
                </a>
                <form method="post" action="/admin/import/readings" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input type="file" class="form-control" name="file" accept=".xlsx,.xls" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-upload"></i> Загрузить показания
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Results -->
{% if result %}
<div class="card card-dashboard mt-4">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-check-circle"></i> Результат импорта</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="alert alert-success mb-0 text-center">
                    <strong>{{ result.created }}</strong> создано
                </div>
            </div>
            <div class="col-md-4">
                <div class="alert alert-warning mb-0 text-center">
                    <strong>{{ result.skipped }}</strong> пропущено
                </div>
            </div>
            <div class="col-md-4">
                <div class="alert alert-{{ 'danger' if result.errors else 'info' }} mb-0 text-center">
                    <strong>{{ result.errors|length }}</strong> ошибок
                </div>
            </div>
        </div>
        {% if result.errors %}
        <details>
            <summary class="text-danger" style="cursor: pointer;">Показать ошибки ({{ result.errors|length }})</summary>
            <ul class="mt-2">
                {% for err in result.errors[:20] %}
                <li class="text-danger small">{{ err }}</li>
                {% endfor %}
                {% if result.errors|length > 20 %}
                <li class="text-muted">... и ещё {{ result.errors|length - 20 }}</li>
                {% endif %}
            </ul>
        </details>
        {% endif %}
    </div>
</div>
{% endif %}
{% endblock %}
</file>

