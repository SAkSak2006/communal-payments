            select(Tariff, UtilityService.name, UtilityService.unit)
            .join(UtilityService, UtilityService.id == Tariff.service_id)
            .where(Tariff.effective_to.is_(None))
            .order_by(UtilityService.name)
        )
        tariffs = result.all()

    if not tariffs:
        await message.answer(
