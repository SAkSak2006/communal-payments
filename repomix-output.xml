            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Сохранить
                </button>
                <a href="/admin/readings" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function updatePrevVal() {
    const select = document.getElementById('meter_id');
    const option = select.options[select.selectedIndex];
    const prevSpan = document.getElementById('prev-val');

    if (option && option.dataset.last !== undefined && option.value !== '') {
        const lastVal = parseFloat(option.dataset.last);
        prevSpan.textContent = lastVal.toFixed(3).replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
    } else {
        prevSpan.textContent = '—';
    }
}
</script>
{% endblock %}
</file>

<file path="app/templates/readings/list.html">
{% extends "base.html" %}

