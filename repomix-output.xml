        <a href="/admin/readings/create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Добавить показание
        </a>
    </div>
</div>

{% set month_names = {0:'Все месяцы',1:'Январь',2:'Февраль',3:'Март',4:'Апрель',5:'Май',6:'Июнь',7:'Июль',8:'Август',9:'Сентябрь',10:'Октябрь',11:'Ноябрь',12:'Декабрь'} %}

<!-- Filter -->
<div class="card card-dashboard mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Год</label>
                <select class="form-select" name="year">
                    <option value="0" {{ 'selected' if year == 0 }}>Все годы</option>
                    {% for y in available_years %}
                    <option value="{{ y }}" {{ 'selected' if y == year }}>{{ y }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Месяц</label>
                <select class="form-select" name="month">
                    <option value="0" {{ 'selected' if month == 0 }}>Все месяцы</option>
                    {% for m in range(1, 13) %}
                    <option value="{{ m }}" {{ 'selected' if m == month }}>{{ month_names[m] }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Статус</label>
                <select class="form-select" name="validated">
                    <option value="">Все</option>
                    <option value="true" {{ 'selected' if validated == 'true' }}>Проверенные</option>
                    <option value="false" {{ 'selected' if validated == 'false' }}>Непроверенные</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Поиск по жителю</label>
                <input type="text" class="form-control" name="q" value="{{ q or '' }}" placeholder="ФИО или лицевой счёт...">
