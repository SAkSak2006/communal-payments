            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-funnel"></i> Применить
                </button>
                <a href="/admin/readings" class="btn btn-outline-secondary">Сброс</a>
            </div>
        </form>
    </div>
</div>

<div class="card card-dashboard">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Житель</th>
                        <th>Адрес</th>
                        <th>Услуга</th>
                        <th>Пред. показ.</th>
                        <th>Текущее</th>
                        <th>Потребление</th>
                        <th>Источник</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in readings %}
                    <tr>
                        <td>{{ r.reading_date.strftime('%d.%m.%Y') }}</td>
                        <td>{{ r.resident_name }}</td>
                        <td>{{ r.address_str }}</td>
                        <td>{{ r.service_name }}</td>
                        <td>{{ r.previous_value }}</td>
                        <td><strong>{{ r.value }}</strong></td>
                        <td>{{ r.consumption }}</td>
                        <td>
                            <span class="badge bg-{{ 'info' if r.source == 'telegram' else 'secondary' }}">
                                {{ r.source }}
                            </span>
                        </td>
                        <td>
                            {% if r.is_validated %}
                            <span class="badge bg-success">Проверено</span>
                            {% else %}
                            <span class="badge bg-warning">Ожидает</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if not r.is_validated %}
                            <a href="/admin/readings/{{ r.id }}/validate" class="btn btn-sm btn-success" title="Подтвердить">
                                <i class="bi bi-check"></i>
                            </a>
                            <a href="/admin/readings/{{ r.id }}/reject" class="btn btn-sm btn-danger" title="Отклонить"
                               onclick="return confirm('Отклонить показание?')">
                                <i class="bi bi-x"></i>
                            </a>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="10" class="text-center text-muted">Показания не найдены</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% include "components/pagination.html" %}
    </div>
</div>
{% endblock %}
</file>

