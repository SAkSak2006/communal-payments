        "Горячее водоснабжение": "🔥",
        "Электроснабжение": "⚡",
        "Газоснабжение": "🔵",
        "Отопление": "🌡",
    }

    text = "📈 <b>Текущие тарифы</b>\n"
    text += "━━━━━━━━━━━━━━━━━━━\n\n"

    for tariff, svc_name, svc_unit in tariffs:
        icon = service_icons.get(svc_name, "▪️")
        price = f"{tariff.price_per_unit:,.4f}".replace(",", " ")
        text += f"  {icon} <b>{svc_name}</b>\n"
