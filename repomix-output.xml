                    <a class="nav-link {% if active == 'dashboard' %}active{% endif %}" href="/admin/">
                        <i class="bi bi-speedometer2"></i> <span>Дашборд</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'residents' %}active{% endif %}" href="/admin/residents">
                        <i class="bi bi-people"></i> <span>Жители</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'tariffs' %}active{% endif %}" href="/admin/tariffs">
                        <i class="bi bi-cash-stack"></i> <span>Тарифы</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'meters' %}active{% endif %}" href="/admin/meters">
                        <i class="bi bi-speedometer"></i> <span>Счётчики</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'readings' %}active{% endif %}" href="/admin/readings">
                        <i class="bi bi-clipboard-data"></i> <span>Показания</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'payments' %}active{% endif %}" href="/admin/payments">
                        <i class="bi bi-credit-card"></i> <span>Платежи</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'charges' %}active{% endif %}" href="/admin/charges">
                        <i class="bi bi-calculator"></i> <span>Начисления</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'reports' %}active{% endif %}" href="/admin/reports">
                        <i class="bi bi-file-earmark-bar-graph"></i> <span>Отчёты</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if active == 'import' %}active{% endif %}" href="/admin/import">
                        <i class="bi bi-cloud-upload"></i> <span>Импорт</span>
                    </a>
                </li>
            </ul>
            <hr class="text-white">
            <div class="mt-auto">
                <a href="#" class="d-flex align-items-center text-decoration-none" style="color:#94a3b8;font-size:.875rem;padding:6px 0;">
                    <i class="bi bi-person-circle" style="margin-right:8px;font-size:1.1rem;"></i> <span>{{ user.full_name }}</span>
                </a>
                <a href="/admin/logout" class="d-flex align-items-center text-decoration-none" style="color:#94a3b8;font-size:.875rem;padding:6px 0;">
                    <i class="bi bi-box-arrow-right" style="margin-right:8px;font-size:1.1rem;color:#f87171;"></i> <span>Выйти</span>
                </a>
            </div>
        </nav>

        <!-- Main content -->
        <main class="flex-grow-1" style="min-height:100vh;background:#f7f9fb;">
            <!-- Top bar -->
            <div style="position:sticky;top:0;z-index:30;background:rgba(247,249,251,.85);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;">
                <div style="display:flex;align-items:center;gap:.5rem;font-size:.8125rem;color:#727785;">
                    <span>Главная</span>
                    <span style="color:#c2c6d6;">/</span>
                    <span style="color:#0058be;font-weight:600;">{% block breadcrumb %}Панель{% endblock %}</span>
                </div>
                <div style="display:flex;align-items:center;gap:1rem;">
                    <button style="width:36px;height:36px;border-radius:50%;border:none;background:transparent;color:#424754;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.2rem;" title="Уведомления"><i class="bi bi-bell"></i></button>
                    <button style="width:36px;height:36px;border-radius:50%;border:none;background:transparent;color:#424754;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.2rem;" title="Настройки"><i class="bi bi-gear"></i></button>
                    <div style="display:flex;align-items:center;gap:.75rem;padding-left:1rem;border-left:1px solid #c2c6d6;">
                        <div style="text-align:right;">
                            <div style="font-size:.8125rem;font-weight:600;color:#191c1e;line-height:1.2;">{{ user.full_name }}</div>
                            <div style="font-size:.625rem;color:#727785;text-transform:uppercase;letter-spacing:.04em;">{{ user.role.value if user.role else 'Оператор' }}</div>
                        </div>
                        <div style="width:34px;height:34px;border-radius:50%;background:#d8e2ff;color:#0058be;font-weight:700;font-size:.8rem;display:flex;align-items:center;justify-content:center;">{{ user.full_name[:1] if user.full_name else 'A' }}</div>
                    </div>
                </div>
            </div>

            <div class="p-4">
                {% if error %}
                <div class="alert alert-danger alert-dismissible fade show">
                    {{ error }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                {% endif %}
                {% if success %}
                <div class="alert alert-success alert-dismissible fade show">
                    {{ success }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                {% endif %}

                {% block content %}{% endblock %}
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
</file>

<file path="app/templates/charges/list.html">
{% extends "base.html" %}

{% block title %}Начисления{% endblock %}
{% block breadcrumb %}Начисления{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="mb-1">Начисления</h2>
        <p class="text-muted mb-0" style="font-size:.875rem;">Расчёт и управление начислениями по периодам</p>
    </div>
</div>

{% set month_names = {1:'Январь',2:'Февраль',3:'Март',4:'Апрель',5:'Май',6:'Июнь',7:'Июль',8:'Август',9:'Сентябрь',10:'Октябрь',11:'Ноябрь',12:'Декабрь'} %}

<!-- Period management -->
<div class="card card-dashboard mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Год</label>
                <select class="form-select" name="year">
                    {% for y in range(2024, 2028) %}
                    <option value="{{ y }}" {{ 'selected' if y == year }}>{{ y }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Месяц</label>
                <select class="form-select" name="month">
                    {% for m in range(1, 13) %}
                    <option value="{{ m }}" {{ 'selected' if m == month }}>{{ month_names[m] }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-funnel"></i> Показать
                </button>
            </div>
            <div class="col-md-2">
                <a href="/admin/charges/calculate?year={{ year }}&month={{ month }}"
                   class="btn btn-success w-100"
                   onclick="return confirm('Рассчитать начисления за {{ '%02d'|format(month) }}.{{ year }}?')">
                    <i class="bi bi-calculator"></i> Рассчитать
                </a>
            </div>
            <div class="col-md-2">
                {% if period and not period.is_closed %}
                <a href="/admin/charges/close?year={{ year }}&month={{ month }}"
                   class="btn btn-warning w-100"
                   onclick="return confirm('Закрыть период {{ '%02d'|format(month) }}.{{ year }}? Это действие нельзя отменить.')">
                    <i class="bi bi-lock"></i> Закрыть период
                </a>
                {% elif period and period.is_closed %}
                <span class="btn btn-secondary w-100 disabled">
                    <i class="bi bi-lock-fill"></i> Период закрыт
                </span>
                {% endif %}
            </div>
            <div class="col-md-2">
                <a href="/admin/charges/notify?year={{ year }}&month={{ month }}"
                   class="btn btn-info w-100 text-white"
                   onclick="return confirm('Отправить уведомления о начислениях за {{ '%02d'|format(month) }}.{{ year }} всем жильцам в Telegram?')">
                    <i class="bi bi-send"></i> Уведомить жильцов
                </a>
            </div>
        </form>
    </div>
</div>

{% if message %}
<div class="alert alert-info">{{ message }}</div>
{% endif %}

<!-- Summary -->
{% if charges %}
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card card-dashboard">
            <div class="card-body text-center">
                <h6 class="text-muted">Всего начислений</h6>
                <h3>{{ charges|length }}</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-dashboard">
            <div class="card-body text-center">
                <h6 class="text-muted">Общая сумма</h6>
                <h3>{{ "{:,.2f}".format(total_amount).replace(",", " ") }} &#8381;</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-dashboard">
            <div class="card-body text-center">
                <h6 class="text-muted">Экспорт</h6>
                <a href="/admin/reports/export?year={{ year }}&month={{ month }}" class="btn btn-outline-success">
                    <i class="bi bi-file-earmark-excel"></i> Скачать Excel
                </a>
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- Table -->
<div class="card card-dashboard">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Житель</th>
                        <th>Лиц. счёт</th>
                        <th>Адрес</th>
                        <th>Услуга</th>
                        <th>Потребление</th>
                        <th>Сумма</th>
                        <th>Квитанция</th>
                    </tr>
                </thead>
                <tbody>
                    {% set ns = namespace(prev_resident='') %}
                    {% for c in charges %}
                    <tr>
                        <td>{{ c.resident_name }}</td>
                        <td><code>{{ c.personal_account }}</code></td>
                        <td>{{ c.address }}</td>
                        <td>{{ c.service_name }}</td>
                        <td>{{ c.consumption }} {{ c.unit }}</td>
                        <td><strong>{{ "{:,.2f}".format(c.amount).replace(",", " ") }}</strong> &#8381;</td>
                        <td>
                            {% if ns.prev_resident != c.resident_name %}
                            <a href="/admin/charges/receipt/{{ c.resident_id }}?year={{ year }}&month={{ month }}"
                               class="btn btn-sm btn-outline-danger" title="Скачать квитанцию PDF">
                                <i class="bi bi-file-earmark-pdf"></i>
                            </a>
                            {% set ns.prev_resident = c.resident_name %}
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            Начислений за этот период нет. Нажмите «Рассчитать».
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="app/templates/components/pagination.html">
{% if total_pages > 1 %}
<nav class="mt-3">
    <ul class="pagination justify-content-center">
        <li class="page-item {{ 'disabled' if page <= 1 }}">
            <a class="page-link" href="?{{ query_params }}&page={{ page - 1 }}">&#8592;</a>
        </li>
        {% for p in range(1, total_pages + 1) %}
            {% if p == page %}
            <li class="page-item active"><span class="page-link">{{ p }}</span></li>
            {% elif p <= 3 or p > total_pages - 2 or (p >= page - 1 and p <= page + 1) %}
            <li class="page-item">
                <a class="page-link" href="?{{ query_params }}&page={{ p }}">{{ p }}</a>
            </li>
            {% elif p == 4 or p == total_pages - 2 %}
            <li class="page-item disabled"><span class="page-link">...</span></li>
            {% endif %}
        {% endfor %}
        <li class="page-item {{ 'disabled' if page >= total_pages }}">
            <a class="page-link" href="?{{ query_params }}&page={{ page + 1 }}">&#8594;</a>
        </li>
    </ul>
    <p class="text-center text-muted small">
        Показано {{ offset + 1 }}–{{ [offset + per_page, total_count]|min }} из {{ total_count }}
    </p>
</nav>
{% endif %}
</file>

<file path="app/templates/dashboard.html">
{% extends "base.html" %}

{% block title %}Дашборд{% endblock %}
{% block breadcrumb %}Дашборд{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="mb-1">Дашборд</h2>
        <p class="text-muted mb-0" style="font-size:.875rem;">Сводка по жилищно-коммунальным услугам</p>
    </div>
</div>

<!-- Stats cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card card-dashboard">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Жители</h6>
                        <h3 class="mb-0">{{ stats.residents_count }}</h3>
                    </div>
                    <i class="bi bi-people fs-1 text-primary"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-dashboard">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Показания (мес.)</h6>
                        <h3 class="mb-0">{{ stats.readings_count }}</h3>
                    </div>
                    <i class="bi bi-clipboard-data fs-1 text-success"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-dashboard">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Общая задолженность</h6>
                        <h3 class="mb-0">{{ "{:,.2f}".format(stats.total_debt).replace(",", " ") }} &#8381;</h3>
                    </div>
                    <i class="bi bi-exclamation-triangle fs-1 text-danger"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-dashboard">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Оплаты (мес.)</h6>
                        <h3 class="mb-0">{{ "{:,.2f}".format(stats.payments_month).replace(",", " ") }} &#8381;</h3>
                    </div>
                    <i class="bi bi-credit-card fs-1 text-info"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Unvalidated readings -->
<div class="row g-4">
    <div class="col-md-8">
        <div class="card card-dashboard">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Непроверенные показания</h5>
            </div>
            <div class="card-body">
                {% if unvalidated_readings %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Дата</th>
                                <th>Житель</th>
                                <th>Услуга</th>
                                <th>Показание</th>
                                <th>Потребление</th>
                                <th>Источник</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for r in unvalidated_readings %}
                            <tr>
                                <td>{{ r.reading_date.strftime('%d.%m.%Y') }}</td>
                                <td>{{ r.resident_name }}</td>
                                <td>{{ r.service_name }}</td>
                                <td>{{ r.value }}</td>
                                <td>{{ r.consumption }}</td>
                                <td>
                                    <span class="badge bg-{{ 'warning' if r.source == 'telegram' else 'secondary' }}">
                                        {{ r.source }}
                                    </span>
                                </td>
                                <td>
                                    <a href="/admin/readings/{{ r.id }}/validate" class="btn btn-sm btn-success">
                                        <i class="bi bi-check"></i>
                                    </a>
                                    <a href="/admin/readings/{{ r.id }}/reject" class="btn btn-sm btn-danger">
                                        <i class="bi bi-x"></i>
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <p class="text-muted mb-0">Все показания проверены</p>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-dashboard">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> Текущие тарифы</h5>
            </div>
            <div class="card-body">
                {% if current_tariffs %}
                <ul class="list-group list-group-flush">
                    {% for t in current_tariffs %}
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        {{ t.service_name }}
                        <span class="badge bg-primary rounded-pill">
                            {{ t.price_per_unit }} &#8381;/{{ t.unit }}
                        </span>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
